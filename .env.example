# MuSecure Contracts – variables de entorno
# Copia como .env — NUNCA subas .env a git

# Deployer (wallet con ETH en Arbitrum)
DEPLOYER_PRIVATE_KEY=0x...

# Backend que firma los authenticityScores
# En dev/testnet puedes usar la misma que el deployer
# En prod debe ser una clave separada solo del backend
SCORE_SIGNER_ADDRESS=0x...

# RPCs
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_ONE_RPC=https://arb1.arbitrum.io/rpc

# Verificación en Arbiscan
ARBISCAN_API_KEY=

# Direcciones post-deploy (rellenar después del primer deploy)
REGISTRY_ADDRESS=
ASSET_ADDRESS=
DEPLOY_BLOCK=
